# ===================================
# DATABASE
# ===================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cotaagro

# ===================================
# REDIS
# ===================================
REDIS_URL=redis://localhost:6379

# ===================================
# SERVER
# ===================================
PORT=3000
NODE_ENV=development

# ===================================
# AUTHENTICATION
# ===================================
# JWT secret - gere com: openssl rand -base64 32
JWT_SECRET=seu_jwt_secret_aqui_mude_em_producao
JWT_EXPIRES_IN=7d

# ===================================
# WHATSAPP PROVIDER
# ===================================
# Opções: twilio | evolution
WHATSAPP_PROVIDER=twilio

# --- Twilio (se WHATSAPP_PROVIDER=twilio) ---
TWILIO_ACCOUNT_SID=seu_account_sid
TWILIO_AUTH_TOKEN=seu_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886

# --- Evolution API (se WHATSAPP_PROVIDER=evolution) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=seu_api_key
EVOLUTION_INSTANCE_NAME=cotaagro

# ===================================
# WEBHOOK
# ===================================
# URL pública do seu backend para receber webhooks do WhatsApp
# Em desenvolvimento local, use ngrok: ngrok http 3000
WEBHOOK_URL=https://seu-dominio.ngrok.io

# ===================================
# OPENAI
# ===================================
# API key da OpenAI para interpretação NLU com GPT-4o
OPENAI_API_KEY=sk-proj-seu_api_key_aqui
OPENAI_MODEL=gpt-4o

# ===================================
# BUSINESS LOGIC
# ===================================
# Tempo em minutos até uma cotação expirar (padrão: 2 horas)
QUOTE_EXPIRY_MINUTES=120

# Intervalo em minutos para verificar cotações a consolidar (padrão: 5 min)
CONSOLIDATE_CHECK_INTERVAL=5

# ===================================
# RATE LIMITING
# ===================================
# Máximo de mensagens por telefone por minuto
MAX_MESSAGES_PER_PHONE_PER_MINUTE=30

# ===================================
# LOGGING
# ===================================
# Níveis: error | warn | info | debug
LOG_LEVEL=info
