# ===================================
# API CONFIGURATION
# ===================================
VITE_API_URL=http://localhost:3000

# ===================================
# ANALYTICS
# ===================================
# Enable analytics tracking (true|false)
VITE_ANALYTICS_ENABLED=false

# Analytics provider: plausible | custom | none
VITE_ANALYTICS_PROVIDER=plausible

# Plausible Analytics configuration
# Get your site ID from https://plausible.io/settings
VITE_ANALYTICS_SITE_ID=cotaagro.com.br

# Custom analytics endpoint (if provider=custom)
# Example: https://analytics.example.com/api/events
VITE_ANALYTICS_ENDPOINT=

# ===================================
# ERROR TRACKING
# ===================================
# Optional: Sentry DSN for error tracking
# Get from https://sentry.io/settings/projects/
VITE_SENTRY_DSN=

# Sentry environment name
VITE_SENTRY_ENVIRONMENT=development

# ===================================
# FEATURE FLAGS
# ===================================
# Enable React Query DevTools in development (true|false)
VITE_ENABLE_DEVTOOLS=true

# Enable performance monitoring (Web Vitals tracking)
VITE_ENABLE_PERFORMANCE_MONITORING=true

# ===================================
# NOTES
# ===================================
# - Plausible is recommended for analytics (lightweight, privacy-focused)
# - Set VITE_ANALYTICS_ENABLED=true in production to enable tracking
# - Performance monitoring has minimal impact on app performance
# - Sentry integration is optional but recommended for production error tracking
